rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: assets
    // Fields:
    //   - name: string (required)
    //   - type: string (required, 'image' or 'text')
    //   - content: string (required, max 800KB to be safe)
    //   - size: number
    //   - mimeType: string
    //   - ownerId: string (required)
    //   - createdAt: timestamp (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "arc.quocphan9999@gmail.com" || 
         request.auth.token.email == "vi.quocphan.tk@gmail.com");
    }

    function isValidAsset(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 255 &&
             data.type in ['image', 'text'] &&
             data.content is string &&
             data.createdAt is timestamp &&
             (!('folderId' in data) || data.folderId is string || data.folderId == null) &&
             (!('storagePath' in data) || data.storagePath is string);
    }

    function isValidFolder(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdAt is timestamp &&
             (!('parentId' in data) || data.parentId is string || data.parentId == null);
    }

    match /folders/{folderId} {
      allow read: if true;
      allow create: if isAdmin() && isValidFolder(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /assets/{assetId} {
      allow read: if true;
      allow create: if isAdmin() && isValidAsset(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
